      "priceMag": "0", "expoIsNeg": true, "expoMag": "8", "confMag": "76400",
      "bidBest": "760000", "askBest": "768000", "bidEmpty": false, "askEmpty": false,
      "baseDecimals": 9, "quoteDecimals": 6,
      "throws": "ZERO_PRICE"
    },
    {
      "name": "E3_price_floors_to_zero_rejected",
      "priceMag": "5", "expoIsNeg": true, "expoMag": "18", "confMag": "1",
      "bidBest": "760000", "askBest": "768000", "bidEmpty": false, "askEmpty": false,
      "baseDecimals": 9, "quoteDecimals": 6,
      "throws": "ZERO_PRICE"
    },
    {
      "name": "E4_expo_too_large_rejected",
      "comment": "expoMag 19 > MAX_EXPO_MAG(18). Move would silently truncate `expo_mag as u8` and/or overflow pow(10,>=39); bound it in BOTH langs so they abort identically (parity, must-fix #7 spirit).",
      "priceMag": "76400000", "expoIsNeg": true, "expoMag": "19", "confMag": "76400",
      "bidBest": "760000", "askBest": "768000", "bidEmpty": false, "askEmpty": false,
      "baseDecimals": 9, "quoteDecimals": 6,
      "throws": "EXPO_TOO_LARGE"
    }
  ]
}
