# Seawall agent — env (all optional; sane defaults baked in).
# IDs + feed come from ../../config/testnet.json (written by the deploy scripts).
# The signing key is loaded at runtime from the CLI keystore via
# `sui keytool export` for config.registeredAgent — NEVER put a key here.

# Control-server port (GET /stream, POST /control/scene, GET /feed-id).
AGENT_PORT=8787
